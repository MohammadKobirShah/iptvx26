# IPTV M3U Playlist Source
# Option 1: URL to M3U file
M3U_URL=https://example.com/playlist.m3u

# Option 2: Direct M3U content (base64 encoded or raw)
# M3U_CONTENT=

# Performance Settings
MAX_WORKERS=100
WORKER_START_DELAY=0.5

# Authentication (optional)
ENABLE_AUTH=false
API_KEY=your-secret-api-key-here

# Logging
LOG_LEVEL=info

# Port (Railway sets this automatically)
PORT=8080

# Proxy Settings (optional)
# ENABLE_PROXY=false
# SOCKS5_URL=socks5://proxy-server:1080
